# === SISMED ===
SISMED_EXE = C:\RUTA\A\sismedv2.exe

SISMED_USERNAME = usuario
SISMED_PASSWORD = password

# === BD KSalud ===
DB_SERVER = 192.168.170.37
DB_NAME = ksalud_qa
DB_USER = rpa
DB_PASS = rpaKsalud

# === MODO DE OPERACION ===
# "continuo" = 24/7, "batch" = rango de fechas
MODO = continuo

# === CONTROL DE FLUJOS (true/false) ===
PROCESAR_INGRESOS = true
PROCESAR_SALIDAS = true
PROCESAR_PEDIDOS = true

# false: salta movimientos con estado de error (01,02,10,20)
# true:  los procesa igual
PROCESAR_ERRORES = false

# === FECHAS (usado si MODO=batch, ignorado si MODO=continuo) ===
FECHA_INI = 2026-06-07
FECHA_FIN = 2026-06-07

# === CIERRE DIARIO ===
HORA_CIERRE = 23:45

# === NOTIFICACIONES POR CORREO ===
SMTP_EMAIL = tu_correo@gmail.com
SMTP_PASSWORD = tu_password_o_app_password
SMTP_DESTINO = destino@ejemplo.com
BOT_NUMBER = 1
NOTIFICAR_CORREO = false

# Descripcion del bot para identificar en correos (opcional)
DESCRIPCION = Bot SISMED
